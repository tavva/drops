{
  "name": "@tavva/drops-cli",
  "version": "0.1.0",
  "description": "Command-line client for browser-authorised uploads to Drops instances.",
  "license": "MIT",
  "author": "Tavva",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tavva/drops.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/tavva/drops#readme",
  "type": "module",
  "bin": {
    "drops": "dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:keychain:live": "DROPS_CLI_LIVE_KEYCHAIN=1 vitest run tests/keychain-live.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/yazl": "^3.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
