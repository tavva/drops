{
  "name": "drops-drops",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "yazl": "^3.3.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/lib-storage": "^3.1032.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "yauzl": "^3.3.0",
    "zod": "^4.3.6"
  }
}
