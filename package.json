{
  "name": "drops",
  "version": "0.0.0",
  "description": "Single-tenant private static-site host. Sign in with Google, upload a folder/zip/file, share the URL.",
  "type": "module",
  "license": "MIT",
  "author": "Ben Phillips <ben@ben-phillips.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tavva/drops.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=.env src/db/migrate.ts",
    "dev:seed": "tsx --env-file=.env scripts/dev-seed.ts",
    "dev:init-bucket": "tsx --env-file=.env scripts/dev-init-bucket.ts",
    "dev:preview": "tsx scripts/preview.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.6.0",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "yazl": "^3.3.1"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "^0.25.0"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/lib-storage": "^3.1032.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.1",
    "@fastify/view": "^11.1.1",
    "drizzle-orm": "^0.45.2",
    "ejs": "^5.0.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "openid-client": "^6.8.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "yauzl": "^3.3.0",
    "zod": "^4.3.6"
  }
}
