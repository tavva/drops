<% /* dropSignin.ejs — logged-out viewer interstitial: Google or magic link */ %>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="dark">
    <title>Sign in to view this drop — drops</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 32'><path d='M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z' fill='%23ff5a3c'/><ellipse cx='8.5' cy='18' rx='2.2' ry='3' fill='%23ffd9cf' opacity='0.55'/></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
    <link rel="stylesheet" href="/app/static/style.css">
  </head>
  <body>
    <div class="auth-wrap">
      <div class="auth-card uname-card">
        <div class="auth-logo">
          <svg viewBox="0 0 24 32" aria-hidden="true">
            <path class="body" d="M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z"/>
            <ellipse class="hl" cx="8.5" cy="18" rx="2.2" ry="3"/>
          </svg>
        </div>
        <h1>Sign in to view this drop</h1>
        <p class="deck"><code><%= host %></code></p>

        <% if (notice) { %><p class="notice" id="notice"><%= notice %></p><% } %>

        <div class="actions">
          <a class="btn primary" href="<%= googleHref %>">Sign in with Google →</a>
        </div>

        <p class="deck">No Google account? We can email you a sign-in link.</p>

        <form method="post" action="/auth/magic/request">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="host" value="<%= host %>">
          <input type="hidden" name="next" value="<%= next %>">
          <div class="field">
            <label for="email">Email</label>
            <div class="input-wrap">
              <input id="email" name="email" type="email" required
                autocomplete="email" spellcheck="false"
                autocapitalize="off" autocorrect="off">
            </div>
          </div>
          <div class="actions">
            <button class="btn" type="submit">Email me a sign-in link →</button>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>
