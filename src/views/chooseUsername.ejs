<% /* chooseUsername.ejs */ %>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Choose a username</title>
  </head>
  <body>
    <h1>Welcome, <%= email %></h1>
    <% if (error) { %><p class="error" id="error"><%= error %></p><% } %>
    <form method="post" action="/auth/choose-username">
      <label>Username <input name="username" value="<%= suggested %>" pattern="^[a-z0-9][a-z0-9-]{0,30}[a-z0-9]$" required></label>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="next" value="<%= next %>">
      <button type="submit">Continue</button>
    </form>
  </body>
</html>
