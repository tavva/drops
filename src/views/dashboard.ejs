<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="dark">
    <title>Drops — <%= user.username %></title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 32'><path d='M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z' fill='%23ff5a3c'/><ellipse cx='8.5' cy='18' rx='2.2' ry='3' fill='%23ffd9cf' opacity='0.55'/></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
    <link rel="stylesheet" href="/app/static/style.css">
  </head>
  <body class="app-viewport">
    <header class="app-header">
      <div class="app-wordmark">
        <svg class="drop" viewBox="0 0 24 32" aria-hidden="true">
          <path class="body" d="M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z"/>
          <ellipse class="hl" cx="8.5" cy="18" rx="2.2" ry="3"/>
        </svg>
        <span>drops</span>
      </div>
      <div class="app-header-right">
        <div class="user-menu" title="<%= user.email %>">
          <span class="avatar"><%= user.username.charAt(0).toUpperCase() %></span>
          <span><%= user.username %></span>
        </div>
        <form class="logout-form" method="post" action="/auth/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="logout-btn" type="submit">Sign out</button>
        </form>
      </div>
    </header>

    <div class="app-main">
      <% if (banner) { %>
        <div class="banner banner-<%= banner.kind %>"><%= banner.message %></div>
      <% } %>

      <div class="page-head">
        <h1>Drops</h1>
        <div class="actions">
          <form method="get" action="/app" class="mine-toggle">
            <label>
              <input type="checkbox" name="mine" value="1"<% if (mineOnly) { %> checked<% } %> onchange="this.form.submit()">
              Mine only
            </label>
          </form>
          <details class="new-folder-details"<% if (form && form.kind === 'create-folder') { %> open<% } %>>
            <summary class="btn">＋ New folder</summary>
            <form method="post" action="/app/folders" class="new-folder-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="text" name="name" maxlength="64" required placeholder="Folder name"
                     value="<%= (form && form.kind === 'create-folder' && form.values.name) ? form.values.name : '' %>">
              <select name="parentId">
                <option value="">— root —</option>
                <% folderPathList.forEach(function(entry) { %>
                  <option value="<%= entry.id %>"<% if (form && form.kind === 'create-folder' && form.values.parentId === entry.id) { %> selected<% } %>><%= entry.path %></option>
                <% }) %>
              </select>
              <button type="submit" class="btn primary">Create</button>
            </form>
          </details>
          <a class="btn primary" href="/app/drops/new"><span class="plus">＋</span> New drop</a>
        </div>
      </div>

      <div class="card">
        <% if (tree.rootFolderIds.length === 0 && tree.rootDrops.length === 0) { %>
          <div class="empty">
            <div class="big-drop">
              <svg viewBox="0 0 24 32" aria-hidden="true">
                <path class="body" d="M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z"/>
              </svg>
            </div>
            <h3>You have no drops yet</h3>
            <p><a href="/app/drops/new">Upload something</a> to get started.</p>
          </div>
        <% } else { %>
          <div class="tree">
            <% tree.rootFolderIds.forEach(function(id) { %>
              <% const node = tree.byId.get(id); if (node) { %>
                <%- include('_folderNode', { node, tree, user, csrfToken, folderPathList, formatBytes, dropOriginFor, form }) %>
              <% } %>
            <% }) %>
            <% tree.rootDrops.forEach(function(d) { %>
              <%- include('_dropRow', { d, user, csrfToken, folderPathList, formatBytes, dropOriginFor }) %>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
    <script>window.__folders = <%- JSON.stringify(folderPathList) %>;</script>
  </body>
</html>
