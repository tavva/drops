<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="dark">
    <title>Drop: <%= drop.name %> — drops</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 32'><path d='M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z' fill='%23ff5a3c'/><ellipse cx='8.5' cy='18' rx='2.2' ry='3' fill='%23ffd9cf' opacity='0.55'/></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
    <link rel="stylesheet" href="/app/static/style.css">
    <script src="/app/static/new-drop.js" defer></script>
  </head>
  <body class="app-viewport">
    <header class="app-header">
      <div class="app-wordmark">
        <svg class="drop" viewBox="0 0 24 32" aria-hidden="true">
          <path class="body" d="M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z"/>
          <ellipse class="hl" cx="8.5" cy="18" rx="2.2" ry="3"/>
        </svg>
        <span>drops</span>
        <span class="sep">/</span>
        <a class="ctx" href="/app">Drops</a>
        <span class="sep">/</span>
        <span class="ctx"><%= drop.name %></span>
      </div>
    </header>

    <div class="app-main">
      <div class="page-head">
        <h1><%= drop.name %></h1>
        <div class="actions">
          <a class="btn" href="<%= contentUrl %>" target="_blank" rel="noreferrer">↗ View live</a>
        </div>
      </div>

      <div class="edit-grid">
        <div>
          <div class="card version-card mb-24">
            <div class="title-row">
              <h3>Current version</h3>
              <% if (drop.version) { %>
                <span class="tag live">● live</span>
              <% } else { %>
                <span class="tag">empty</span>
              <% } %>
            </div>
            <div class="link-row">
              <span class="drop-url">
                <span class="host"><%= new URL(contentUrl).origin %>/</span><span class="path"><%= new URL(contentUrl).pathname.replace(/^\//, '') %></span>
              </span>
              <div class="spacer"></div>
              <a href="<%= contentUrl %>" target="_blank" rel="noreferrer">open ↗</a>
            </div>
            <% if (drop.version) { %>
              <dl class="version-kv">
                <dt>Files</dt><dd><%= drop.version.fileCount %> files</dd>
                <dt>Size</dt><dd><%= formatBytes(drop.version.byteSize) %></dd>
                <dt>Version</dt><dd class="v-mono"><%= drop.version.id %></dd>
              </dl>
            <% } else { %>
              <p class="hint">No version uploaded yet.</p>
            <% } %>
          </div>

          <form id="new-drop-form" class="card" data-csrf="<%= csrfToken %>" data-fixed-name="<%= drop.name %>">
            <div class="section-head">
              <h2>Replace contents</h2>
              <div class="spacer"></div>
              <span class="pill">atomic</span>
            </div>
            <div id="drop-zone" class="dropzone" style="padding: 36px 24px;">
              <div class="big-drop" style="width: 52px; height: 66px;">
                <svg viewBox="0 0 24 32" aria-hidden="true">
                  <path class="body" d="M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z"/>
                  <ellipse class="hl" cx="8.5" cy="18" rx="2.2" ry="3"/>
                </svg>
              </div>
              <h2 style="font-size: 18px;">Replace contents</h2>
              <p class="sub">Folder, zip, or a single file.</p>
              <div class="pickers">
                <label class="picker-btn">Files
                  <input type="file" id="drop-files" multiple>
                </label>
                <label class="picker-btn">Folder
                  <input type="file" id="drop-folder" multiple webkitdirectory>
                </label>
              </div>

              <div id="ready-pill" class="ready-pill" hidden></div>

              <div class="upload-meter">
                <div class="label"><span id="progress">Uploading…</span><span class="pct" id="upload-pct">0%</span></div>
                <div class="bar"><div class="fill" id="upload-fill"></div></div>
              </div>
            </div>

            <p id="error" class="error" hidden></p>

            <div class="newdrop-actions">
              <button class="btn primary" type="submit">Upload new version</button>
            </div>
          </form>

          <div class="card mt-16" style="padding: 18px 20px;">
            <div class="section-head">
              <h2>Who can view</h2>
              <div class="spacer"></div>
              <% if (drop.viewMode === 'public') { %><span class="tag">public</span>
              <% } else if (drop.viewMode === 'emails') { %><span class="tag">list</span>
              <% } else { %><span class="tag">members</span><% } %>
            </div>

            <form method="post" action="/app/drops/<%= drop.name %>/permissions" class="permissions-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <label class="perm-choice">
                <input type="radio" name="mode" value="authed" <%= drop.viewMode === 'authed' ? 'checked' : '' %>>
                <span class="perm-label">
                  <strong>Any member</strong>
                  <span class="hint">Default. Anyone who can sign in to this instance.</span>
                </span>
              </label>
              <label class="perm-choice">
                <input type="radio" name="mode" value="public" <%= drop.viewMode === 'public' ? 'checked' : '' %>>
                <span class="perm-label">
                  <strong>Public</strong>
                  <span class="hint">Any Google account. No allowlist check.</span>
                </span>
              </label>
              <label class="perm-choice">
                <input type="radio" name="mode" value="emails" <%= drop.viewMode === 'emails' ? 'checked' : '' %>>
                <span class="perm-label">
                  <strong>Specific people</strong>
                  <span class="hint">Only the email addresses you list below.</span>
                </span>
              </label>
              <div class="newdrop-actions">
                <button class="btn primary sm" type="submit">Save</button>
              </div>
            </form>

            <% if (drop.viewMode === 'emails') { %>
              <div class="divider"></div>
              <h3 style="font-size: 14px; margin-bottom: 10px;">Permitted viewers</h3>

              <% if (viewerError) { %>
                <p class="hint err" id="viewer-error"><%= viewerError %></p>
              <% } %>

              <form method="post" action="/app/drops/<%= drop.name %>/viewers" class="viewer-add">
                <div class="field">
                  <div class="input-wrap">
                    <input type="email" name="email" required autocomplete="off"
                           spellcheck="false" placeholder="name@example.com">
                  </div>
                </div>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn sm" type="submit">Add</button>
              </form>

              <% if (viewers.length === 0) { %>
                <p class="hint">No viewers yet — only you can see this drop.</p>
              <% } else { %>
                <ul class="viewer-list">
                  <% viewers.forEach(function(v) { %>
                    <li>
                      <span class="email"><%= v.email %></span>
                      <form method="post"
                            action="/app/drops/<%= drop.name %>/viewers/<%= encodeURIComponent(v.email) %>/delete">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn ghost sm" type="submit" title="remove">✕</button>
                      </form>
                    </li>
                  <% }) %>
                </ul>
              <% } %>
            <% } %>
          </div>
        </div>

        <div>
          <div class="card side-card danger">
            <h3>Delete drop</h3>
            <p>Removes the drop, all versions, and its R2 prefix. Not reversible.</p>
            <button class="btn danger sm" id="delete-btn" type="button">Delete <%= drop.name %>…</button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal-bg" id="delete-modal" hidden>
      <div class="modal">
        <h3>Delete <%= drop.name %>?</h3>
        <p>This removes the drop, all versions, and every file in its R2 prefix. It cannot be undone. Type <code><%= drop.name %></code> to confirm.</p>
        <form method="post" action="/app/drops/<%= drop.name %>/delete" id="delete-form">
          <div class="field">
            <div class="input-wrap">
              <input type="text" id="delete-confirm" autocomplete="off" spellcheck="false" placeholder="<%= drop.name %>">
            </div>
          </div>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="actions">
            <button class="btn ghost" type="button" id="delete-cancel">Cancel</button>
            <button class="btn danger" type="submit" id="delete-submit" disabled>Delete</button>
          </div>
        </form>
      </div>
    </div>

    <script>
      (() => {
        const dropName = <%- JSON.stringify(drop.name) %>;
        const bg = document.getElementById('delete-modal');
        const openBtn = document.getElementById('delete-btn');
        const cancelBtn = document.getElementById('delete-cancel');
        const confirmInput = document.getElementById('delete-confirm');
        const submitBtn = document.getElementById('delete-submit');
        if (!bg || !openBtn) return;
        openBtn.addEventListener('click', () => { bg.hidden = false; confirmInput.focus(); });
        cancelBtn.addEventListener('click', () => { bg.hidden = true; });
        bg.addEventListener('click', (e) => { if (e.target === bg) bg.hidden = true; });
        confirmInput.addEventListener('input', () => {
          submitBtn.disabled = confirmInput.value !== dropName;
        });
      })();
    </script>
  </body>
</html>
