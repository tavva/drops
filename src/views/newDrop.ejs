<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="dark">
    <title>New drop — drops</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 32'><path d='M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z' fill='%23ff5a3c'/><ellipse cx='8.5' cy='18' rx='2.2' ry='3' fill='%23ffd9cf' opacity='0.55'/></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
    <link rel="stylesheet" href="/app/static/style.css">
    <script type="module" src="/app/static/new-drop.js"></script>
  </head>
  <body class="app-viewport">
    <header class="app-header">
      <div class="app-wordmark">
        <svg class="drop" viewBox="0 0 24 32" aria-hidden="true">
          <path class="body" d="M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z"/>
          <ellipse class="hl" cx="8.5" cy="18" rx="2.2" ry="3"/>
        </svg>
        <span>drops</span>
        <span class="sep">/</span>
        <a class="ctx" href="/app">Drops</a>
        <span class="sep">/</span>
        <span class="ctx">New</span>
      </div>
    </header>

    <div class="app-main newdrop-wrap">
      <div class="page-head">
        <h1>New drop</h1>
      </div>

      <form id="new-drop-form" class="card" data-csrf="<%= csrfToken %>">
        <div class="field">
          <label for="drop-name">Drop name</label>
          <div class="input-wrap">
            <input id="drop-name" name="name" placeholder="my-drop"
              pattern="^[a-z0-9][a-z0-9-]{0,30}[a-z0-9]$" required
              autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" inputmode="url"
              minlength="2" maxlength="32">
            <span class="suffix">/</span>
          </div>
          <p class="hint">2–32 characters. Lowercase letters, digits, and hyphens. Kebab-case, like a URL.</p>
        </div>

        <div id="drop-zone" class="dropzone">
          <div class="big-drop">
            <svg viewBox="0 0 24 32" aria-hidden="true">
              <path class="body" d="M12 2 C 12 2, 2 15, 2 22 a10 10 0 0 0 20 0 C 22 15, 12 2, 12 2 Z"/>
              <ellipse class="hl" cx="8.5" cy="18" rx="2.2" ry="3"/>
            </svg>
          </div>
          <h2>Drop files here</h2>
          <p class="sub">Folder, zip, or a single file.</p>
          <div class="pickers">
            <label class="picker-btn">Choose files
              <input type="file" id="drop-files" multiple>
            </label>
            <label class="picker-btn">Choose a folder
              <input type="file" id="drop-folder" multiple webkitdirectory>
            </label>
          </div>
          <div class="limits">
            <span><span class="k">total</span> ≤ 100 MB</span>
            <span><span class="k">each</span> ≤ 25 MB</span>
            <span><span class="k">ignored</span> .DS_Store · Thumbs.db · __MACOSX</span>
          </div>

          <div id="ready-pill" class="ready-pill" hidden></div>

          <div class="upload-meter">
            <div class="label"><span id="progress">Uploading…</span><span class="pct" id="upload-pct">0%</span></div>
            <div class="bar"><div class="fill" id="upload-fill"></div></div>
          </div>
        </div>

        <p id="error" class="error" hidden></p>

        <div class="newdrop-actions">
          <a class="btn ghost" href="/app">Cancel</a>
          <button class="btn primary" type="submit">Upload</button>
        </div>
      </form>
    </div>
  </body>
</html>
