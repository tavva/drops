<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>New drop</title>
    <link rel="stylesheet" href="/app/static/style.css">
    <script src="/app/static/new-drop.js" defer></script>
  </head>
  <body>
    <h1>New drop</h1>
    <form id="new-drop-form" data-csrf="<%= csrfToken %>">
      <label for="drop-name">Name</label>
      <input name="name" id="drop-name" pattern="^[a-z0-9][a-z0-9-]{0,30}[a-z0-9]$" required
        autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" inputmode="url"
        minlength="2" maxlength="32"
        title="Lowercase letters, digits and hyphens. 2–32 characters. No spaces.">
      <p class="hint">Used in the URL — lowercase letters, digits, and hyphens. No spaces. 2–32 characters.</p>
      <div id="drop-zone">
        <p>Drag a folder, a .zip, or any file here — or pick below.</p>
        <p class="pickers">
          <label class="picker"><strong>Files:</strong> <input type="file" id="drop-files" multiple></label>
          <label class="picker"><strong>Folder:</strong> <input type="file" id="drop-folder" multiple webkitdirectory></label>
        </p>
      </div>
      <p id="progress"></p>
      <p id="error" class="error"></p>
      <button type="submit">Upload</button>
    </form>
    <p><a href="/app">Back to dashboard</a></p>
  </body>
</html>
