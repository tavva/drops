DATABASE_URL=postgres://drops:drops@localhost:55432/drops
R2_ENDPOINT=http://localhost:9000
R2_ACCOUNT_ID=minio
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=drops
GOOGLE_CLIENT_ID=__fill_me__
GOOGLE_CLIENT_SECRET=__fill_me__
SESSION_SECRET=__generate_64_hex_bytes__
ALLOWED_DOMAIN=example.com
APP_ORIGIN=http://drops.localtest.me:3000
CONTENT_ORIGIN=http://content.localtest.me:3000
PORT=3000
LOG_LEVEL=info
# Email delivery for magic-link viewer sign-in. 'console' (default) captures links in
# logs only — no real delivery. Set to 'resend' (with MAIL_FROM + RESEND_API_KEY) to send.
MAIL_PROVIDER=console
# MAIL_FROM=drops@example.com
# RESEND_API_KEY=__fill_me__
